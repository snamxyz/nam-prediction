{
  "name": "@nam-prediction/api",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "bun run --watch src/index.ts",
    "prebuild": "bun scripts/clean-dist.ts",
    "build": "bun build src/index.ts --outdir dist --target bun --external bullmq --external ioredis",
    "start": "bun run dist/index.js",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "bun run push-schema.ts",
    "db:push:drizzle": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "market:create:hourly": "bun run src/scripts/create-hourly-market.ts",
    "market:seed:daily": "bun run src/scripts/seed-market.ts",
    "range:replace-active": "bun run scripts/replace-active-range-markets.ts",
    "range:verify-quote": "bun run scripts/verify-range-quote.ts"
  },
  "dependencies": {
    "@elysiajs/cors": "^1.4.1",
    "@nam-prediction/shared": "*",
    "@privy-io/server-auth": "^1.32.5",
    "bullmq": "^5.73.3",
    "drizzle-orm": "^0.39.0",
    "elysia": "^1.2.0",
    "ioredis": "^5.10.1",
    "postgres": "^3.4.0",
    "socket.io": "^4.7.0",
    "viem": "^2.21.0"
  },
  "devDependencies": {
    "drizzle-kit": "^0.30.0",
    "typescript": "^5.7.0",
    "@types/bun": "^1.2.19"
  }
}
